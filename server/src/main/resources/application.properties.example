# Spring Application Configuration Example
# Copy this file to application.properties and update with your values

spring.application.name=portfolio

# Database Configuration
spring.datasource.url=jdbc:postgresql://localhost:5432/portfolio
spring.datasource.username=your_db_username
spring.datasource.password=your_db_password
spring.datasource.driver-class-name=org.postgresql.Driver

# JPA Configuration
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=true

# Server Configuration
server.port=8080

# CORS Configuration (handled in SecurityConfig)
# Allowed origins: http://localhost:4200 (development)

# Security Configuration
# Make sure to create admin users through registration with isAdmin=true in database
